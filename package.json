{
  "name": "@deskpro/apps-youtrack",
  "version": "0.1.0-beta.6",
  "description": "This application adds support for viewing and creating Youtrack issues.",
  "main": "lib/main/javascript/index.js",
  "scripts": {
    "dev": "dpat server .",
    "lint": "eslint src/main/javascript/* --ext .js,.jsx --cache --cache-location=.cache/eslint",
    "lint:fix": "npm run lint -- --fix",
    "package": "dpat clean . && dpat compile . && dpat bundle-installer . && dpat verify ./dist && dpat package .",
    "test": "dpat test .",
    "version": "version-changelog CHANGELOG.md && changelog-verify CHANGELOG.md && git add CHANGELOG.md",
    "dpat": "dpat"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DeskproApps/youtrack.git"
  },
  "keywords": [
    "deskpro",
    "react",
    "youtrack"
  ],
  "author": {
    "name": "Deskpro Ltd.",
    "email": "apps@deskpro.com",
    "url": "https://www.deskpro.com"
  },
  "license": "BSD-3-Clause",
  "bugs": {
    "url": "https://github.com/DeskproApps/youtrack/issues"
  },
  "homepage": "https://github.com/DeskproApps/youtrack#readme",
  "deskpro": {
    "version": "2.3.0",
    "title": "Youtrack",
    "isSingle": true,
    "scope": "agent",
    "storage": [
      {
        "name": "oauth:youtrack",
        "isBackendOnly": true,
        "permRead": "EVERYBODY",
        "permWrite": "OWNER"
      },
      {
        "name": "user_settings",
        "isBackendOnly": false,
        "permRead": "OWNER",
        "permWrite": "OWNER"
      }
    ],
    "settings": [
      {
        "name": "youtrackClientId",
        "defaultValue": "",
        "title": "The client id",
        "required": true,
        "type": "text"
      },
      {
        "name": "youtrackClientSecret",
        "defaultValue": "",
        "title": "The client secret",
        "required": true,
        "type": "text"
      },
      {
        "name": "youtrackServiceId",
        "defaultValue": "",
        "title": "The Youtrack service id (from HUB) ",
        "required": true,
        "type": "text"
      },
      {
        "name": "youtrackHubUrl",
        "defaultValue": "https://deskpro-radu.myjetbrains.com/hub",
        "title": "The Youtrack HUB url",
        "required": true,
        "type": "text"
      },
      {
        "name": "urlRedirect",
        "defaultValue": "",
        "title": "The Youtrack redirect URL",
        "required": true,
        "type": "text"
      }
    ],
    "customFields": [
      {
        "type": "dataList",
        "attachedTo": "ticket",
        "alias": "youtrackCards",
        "title": "Youtrack linked issues"
      }
    ],
    "targets": [
      {
        "target": "ticket-sidebar",
        "url": "html/index.html"
      }
    ],
    "deskproApiTags": [],
    "externalApis": [
      "/^https?://([^.]+\\.)*myjetbrains.com/?.*$/"
    ]
  },
  "devDependencies": {
    "@deskpro/apps-dpat": "0.10.4",
    "@deskpro/apps-installer": "github:deskpro/apps-installer#v0.4.5",
    "@deskpro/apps-sdk-core": "^1.0.0-beta.29",
    "@deskpro/apps-sdk-react": "0.2.13",
    "babel-eslint": "^8.0.1",
    "enzyme": "^3.3.0",
    "enzyme-adapter-react-15": "^1.0.5",
    "eslint": "^3.19.0",
    "eslint-config-airbnb": "^15.0.2",
    "eslint-plugin-compat": "^1.0.4",
    "eslint-plugin-import": "^2.7.0",
    "eslint-plugin-jsx-a11y": "^5.1.1",
    "eslint-plugin-promise": "^3.5.0",
    "eslint-plugin-react": "^7.1.0",
    "jest-fetch-mock": "^1.4.0",
    "lodash": "4.17.4",
    "react": "^15.6.2",
    "react-dom": "^15.6.2",
    "react-test-renderer": "^15.6.2"
  },
  "dependencies": {
    "@deskpro/react-components": "1.3.12",
    "@deskpro/redux-components": "^1.0.1",
    "prop-types": "^15.5.10",
    "react-redux": "^5.0.6",
    "redux": "^3.7.2",
    "redux-form": "^7.1.2",
    "redux-thunk": "^2.2.0"
  },
  "optionalDependencies": {
    "changelog-verify": "^1.0.4",
    "version-changelog": "^2.1.0"
  }
}
